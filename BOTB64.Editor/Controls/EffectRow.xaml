<UserControl x:Class="BOTB64.Editor.Controls.EffectRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:models="clr-namespace:BOTB64.Editor.Models"
             xmlns:controls="clr-namespace:BOTB64.Editor.Controls"
             xmlns:entities="clr-namespace:BOTB64.Entities;assembly=BOTB64.Client">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="EffectSourceValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="entities:EffectSourceType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="EffectDamageTypeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="entities:EffectDamageType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="EffectDamageScalingValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="entities:EffectDamageScaling"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,4">
        <WrapPanel Orientation="Horizontal">
            <TextBox Text="{Binding Script, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="0,0,6,0"
                     ToolTip="Script name (no extension)"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                <TextBlock Text="Trigger:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <controls:FlagsPicker EnumType="{x:Type entities:EffectTrigger}" Value="{Binding Trigger, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                <TextBlock Text="Source:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding Source={StaticResource EffectSourceValues}}"
                          SelectedItem="{Binding Source}" Width="100"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                <TextBlock Text="Damage:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding Source={StaticResource EffectDamageTypeValues}}"
                          SelectedItem="{Binding Type}" Width="100"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                <TextBlock Text="Scaling:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding Source={StaticResource EffectDamageScalingValues}}"
                          SelectedItem="{Binding Scaling}" Width="100"/>
            </StackPanel>

            <Button x:Name="RemoveButton" Content="Remove" Click="RemoveButton_Click" Padding="6,2"/>
        </WrapPanel>
    </Border>
</UserControl>
