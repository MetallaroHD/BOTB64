<UserControl x:Class="BOTB64.Editor.Controls.ParameterRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:models="clr-namespace:BOTB64.Editor.Models"
             xmlns:conv="clr-namespace:BOTB64.Editor.Converters"
             xmlns:runtime="clr-namespace:BOTB64.Runtime;assembly=BOTB64.Client">
    <UserControl.Resources>
        <conv:ParamTypeVisibilityConverter x:Key="ParamTypeVisibility"/>
        <ObjectDataProvider x:Key="ParameterTypeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="runtime:ParameterType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="0,4">
        <StackPanel Orientation="Horizontal">
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="0,0,6,0"
                     ToolTip="Parameter name"/>

            <ComboBox ItemsSource="{Binding Source={StaticResource ParameterTypeValues}}"
                      SelectedItem="{Binding Type}" Width="90" Margin="0,0,6,0"/>

            <CheckBox IsChecked="{Binding BoolValue}" VerticalAlignment="Center" Margin="0,0,6,0"
                      Visibility="{Binding Type, Converter={StaticResource ParamTypeVisibility}, ConverterParameter=Boolean}"/>

            <TextBox Text="{Binding IntValue, UpdateSourceTrigger=PropertyChanged}" Width="90" Margin="0,0,6,0"
                     Visibility="{Binding Type, Converter={StaticResource ParamTypeVisibility}, ConverterParameter=Integer}"/>

            <TextBox Text="{Binding FloatValue, UpdateSourceTrigger=PropertyChanged}" Width="90" Margin="0,0,6,0"
                     Visibility="{Binding Type, Converter={StaticResource ParamTypeVisibility}, ConverterParameter=Float}"/>

            <TextBox Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}" Width="160" Margin="0,0,6,0"
                     Visibility="{Binding Type, Converter={StaticResource ParamTypeVisibility}, ConverterParameter=String}"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,6,0"
                        Visibility="{Binding Type, Converter={StaticResource ParamTypeVisibility}, ConverterParameter=Vector}">
                <TextBox Text="{Binding VecX, UpdateSourceTrigger=PropertyChanged}" Width="50" ToolTip="X"/>
                <TextBox Text="{Binding VecY, UpdateSourceTrigger=PropertyChanged}" Width="50" Margin="2,0" ToolTip="Y"/>
                <TextBox Text="{Binding VecZ, UpdateSourceTrigger=PropertyChanged}" Width="50" ToolTip="Z"/>
            </StackPanel>

            <Button Content="Remove" Click="RemoveButton_Click" Padding="6,2"/>
        </StackPanel>
    </Border>
</UserControl>
