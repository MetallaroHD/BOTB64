<UserControl x:Class="BOTB64.Editor.Views.SpellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:models="clr-namespace:BOTB64.Editor.Models"
             xmlns:controls="clr-namespace:BOTB64.Editor.Controls"
             xmlns:entities="clr-namespace:BOTB64.Entities;assembly=BOTB64.Client"
             xmlns:engine="clr-namespace:BOTB64.Engine;assembly=BOTB64.Client">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="TargetingTypeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="engine:TargetingType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style TargetType="Label">
            <Setter Property="Padding" Value="0,4,8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">
            <TextBlock Text="Spell" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

            <UniformGrid Columns="4">
                <Label Content="Target"/>
                <ComboBox ItemsSource="{Binding Source={StaticResource TargetingTypeValues}}" SelectedItem="{Binding ExplicitTarget}" Margin="0,3"/>
                <Label Content="Range"/><TextBox Text="{Binding Range, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Cooldown"/><TextBox Text="{Binding Cooldown, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Charges"/><TextBox Text="{Binding Charges, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Cost"/><TextBox Text="{Binding Cost, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Cost %"/><TextBox Text="{Binding CostPct, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Cost HP"/><TextBox Text="{Binding CostHP, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Preparation"/><TextBox Text="{Binding Preparation, UpdateSourceTrigger=PropertyChanged}"/>
            </UniformGrid>

            <Label Content="Tooltip" Margin="0,10,0,0"/>
            <TextBox Text="{Binding Tooltip, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50"/>

            <TextBlock Text="Parameters" FontWeight="Bold" Margin="0,16,0,4"/>
            <ItemsControl ItemsSource="{Binding Parameters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:ParameterRow RemoveRequested="ParameterRow_RemoveRequested"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="+ Add Parameter" HorizontalAlignment="Left" Margin="0,6" Padding="8,3" Click="AddParameter_Click"/>

            <TextBlock Text="Effects (run in sequence when cast, trigger should be Direct)" FontWeight="Bold" Margin="0,16,0,4"/>
            <ItemsControl ItemsSource="{Binding Effects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:EffectRow RemoveRequested="EffectRow_RemoveRequested"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Button Content="+ Add Effect" HorizontalAlignment="Left" Margin="0,6" Padding="8,3" Click="AddEffect_Click"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
