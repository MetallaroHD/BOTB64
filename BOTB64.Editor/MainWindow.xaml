<Window x:Class="BOTB64.Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BOTB64.Editor.ViewModels"
        xmlns:models="clr-namespace:BOTB64.Editor.Models"
        xmlns:views="clr-namespace:BOTB64.Editor.Views"
        xmlns:io="clr-namespace:BOTB64.Editor.IO"
        xmlns:conv="clr-namespace:BOTB64.Editor.Converters"
        Title="BOTB64 Data Editor" Height="800" Width="1100">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <DataTemplate DataType="{x:Type models:CharacterModel}">
            <views:CharacterView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:SpellModel}">
            <views:SpellView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:AuraModel}">
            <views:AuraView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type models:TileEffectModel}">
            <views:TileEffectView/>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open..." Command="{Binding OpenCommand}"/>
                <MenuItem Header="_Save" Command="{Binding SaveCommand}"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}"/>
                <Separator/>
                <MenuItem Header="New">
                    <MenuItem Header="Character (.b64c)" Command="{Binding NewCommand}"
                              CommandParameter="{x:Static io:FileKind.Character}"/>
                    <MenuItem Header="Spell (.b64s)" Command="{Binding NewCommand}"
                              CommandParameter="{x:Static io:FileKind.Spell}"/>
                    <MenuItem Header="Aura (.b64a)" Command="{Binding NewCommand}"
                              CommandParameter="{x:Static io:FileKind.Aura}"/>
                    <MenuItem Header="Tile Effect (.b64t)" Command="{Binding NewCommand}"
                              CommandParameter="{x:Static io:FileKind.TileEffect}"/>
                </MenuItem>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Open" Command="{Binding OpenCommand}" Padding="8,3"/>
                <Button Content="Save" Command="{Binding SaveCommand}" Padding="8,3" Margin="4,0,0,0"/>
                <Button Content="Save As" Command="{Binding SaveAsCommand}" Padding="8,3" Margin="4,0,0,0"/>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusText}"/>
        </StatusBar>

        <Grid>
            <ContentControl Content="{Binding CurrentEntity}"/>

            <TextBlock Text="Open a .b64c / .b64s / .b64a / .b64t file, or use File &gt; New, to start editing."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="16"
                       Visibility="{Binding CurrentEntity, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Visible}"/>
        </Grid>
    </DockPanel>
</Window>
